DATABASE_URL=postgres://squeeze:squeeze@localhost:5432/squeezeintel
REDIS_URL=redis://localhost:6379
FMP_API_KEY=
# Powers primary market-state ingestion (quotes, move1D, volume, relative-volume) via apps/web/lib/providers/fmp.ts
FINNHUB_API_KEY=
# Powers catalyst/news enrichment via apps/web/lib/providers/finnhub.ts
FULCRUM_ACCESS_KEY=
# Required in production to gate product routes (/platform, /regional-monitor, /alerts-center, /symbol/* and protected APIs).
FULCRUM_ALLOW_STATUS_SIMULATION=false
# Keep false in production. Enables ?simulate=... provider-status overrides for internal testing only.
ORTEX_API_KEY=
# Optional premium source for direct borrow-fee (cost-to-borrow) data via apps/web/lib/providers/borrow.ts
ORTEX_DEFAULT_MIC=XNYS
# Optional ORTEX market code for borrow endpoint resolution
ORTEX_CTB_PATH_TEMPLATE=/api/v1/stock/{mic}/{ticker}/ctb/all?limit=1
# Optional endpoint template override if ORTEX tenant path differs
