{
  "name": "squeeze-intelligence-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @squeeze/web dev",
    "build": "pnpm --filter @squeeze/web build",
    "start": "pnpm --filter @squeeze/web start",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @squeeze/db migrate",
    "db:seed": "pnpm --filter @squeeze/db seed",
    "worker:run": "pnpm --filter @squeeze/worker run"
  }
}
